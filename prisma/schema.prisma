generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum ProductSource {
  REGULAR
  EXCHANGE_THIRD_PARTY
}

enum PaymentMethod {
  CASH
  UPI
}

enum CustomerType {
  MONEY
  EXCHANGE
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name         String
  email        String @unique
  passwordHash String

  role Role @default(EMPLOYEE)

  sales     Sale[]
  exchanges Exchange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shop {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  shopName    String
  shopCode    String  @unique
  address     String?
  phone       String?
  description String?

  products Product[]
  categories Category[]
  sales      Sale[]
  exchanges Exchange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  shopId String? @db.ObjectId
  shop   Shop?   @relation(fields: [shopId], references: [id])

  subcategories SubCategory[]
  products      Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

model SubCategory {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  categoryId String @db.ObjectId

  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  productCode String @unique
  productName String

  shopId        String @db.ObjectId
  categoryId    String @db.ObjectId
  subcategoryId String @db.ObjectId

  purchasePrice Float?
  price         Float
  stock         Int
  source        ProductSource? @default(REGULAR)

  imageUrl    String?
  mainImageUrl String?
  galleryImageUrls String[] @default([])
  imeiNumber String?
  description String?
  qrCode      String?
  barcode     String?

  shop        Shop        @relation(fields: [shopId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])
  subcategory SubCategory @relation(fields: [subcategoryId], references: [id])
  sales       Sale[]
  soldExchanges     Exchange[] @relation("SoldProduct")
  receivedExchanges Exchange[] @relation("ReceivedProduct")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model ProductHistory {
  id                String @id @default(auto()) @map("_id") @db.ObjectId
  originalProductId String @unique
  productCode       String
  productName       String

  shopId        String
  shopName      String
  categoryId    String
  categoryName  String
  subcategoryId String
  subcategoryName String

  purchasePrice Float?
  price         Float
  stock         Int
  source        ProductSource? @default(REGULAR)

  imageUrl          String?
  mainImageUrl      String?
  galleryImageUrls  String[] @default([])
  imeiNumber        String?
  description       String?
  qrCode            String?
  barcode           String?

  saleCount     Int @default(0)
  exchangeCount Int @default(0)

  productCreatedAt String
  productUpdatedAt String
  deletedAt        String
  createdAt        String?

  @@index([productCode])
  @@index([shopId])
  @@index([categoryId])
  @@index([subcategoryId])
}

model Exchange {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  employeeId        String @db.ObjectId
  shopId            String @db.ObjectId
  soldProductId     String @db.ObjectId
  receivedProductId String @db.ObjectId

  soldProductCode String
  soldProductName String
  soldProductPrice Float

  receivedProductCode String
  receivedProductName String
  receivedProductPrice Float
  exchangeValue       Float
  cashBalance         Float
  paymentMethod       PaymentMethod? @default(CASH)
  receivedProductImeiNumber String?
  proofType           String?
  proofFrontImageUrl  String?
  proofBackImageUrl   String?
  proofFrontPublicId  String?
  proofBackPublicId   String?
  condition           String?
  notes               String?

  employee        User    @relation(fields: [employeeId], references: [id])
  shop            Shop    @relation(fields: [shopId], references: [id])
  soldProduct     Product? @relation("SoldProduct", fields: [soldProductId], references: [id])
  receivedProduct Product? @relation("ReceivedProduct", fields: [receivedProductId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([shopId])
  @@index([soldProductId])
  @@index([receivedProductId])
}

model Customer {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  customerName String
  phone        String
  type         CustomerType

  employeeId    String @db.ObjectId
  employeeName  String
  employeeEmail String
  shopId        String @db.ObjectId
  shopName      String

  receivedProductId   String @db.ObjectId
  receivedProductCode String
  receivedProductName String
  exchangeId          String? @db.ObjectId

  amount      Float
  resalePrice Float
  imeiNumber  String?
  proofType   String?
  proofFrontImageUrl String?
  proofBackImageUrl  String?

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([shopId])
  @@index([type])
  @@index([phone])
}

model Sale {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  employeeId String @db.ObjectId
  productId  String @db.ObjectId
  shopId     String @db.ObjectId

  productCode String
  productName String
  quantity    Int

  unitPrice     Float
  purchasePrice Float?
  discount      Float  @default(0)
  totalAmount   Float
  profit        Float
  proofType     String?
  proofFrontImageUrl  String?
  proofBackImageUrl   String?
  proofFrontPublicId  String?
  proofBackPublicId   String?

  employee User    @relation(fields: [employeeId], references: [id])
  product  Product? @relation(fields: [productId], references: [id])
  shop     Shop    @relation(fields: [shopId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([productId])
  @@index([shopId])
}
