generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String   @unique

  name      String
  email     String   @unique

  role      Role     @default(EMPLOYEE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}