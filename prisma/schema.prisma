generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum ProductSource {
  REGULAR
  EXCHANGE_THIRD_PARTY
}

enum PaymentMethod {
  CASH
  UPI
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name         String
  email        String @unique
  passwordHash String

  role Role @default(EMPLOYEE)

  sales     Sale[]
  exchanges Exchange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shop {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  shopName    String
  shopCode    String  @unique
  address     String?
  phone       String?
  description String?

  products Product[]
  categories Category[]
  sales      Sale[]
  exchanges Exchange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  shopId String? @db.ObjectId
  shop   Shop?   @relation(fields: [shopId], references: [id])

  subcategories SubCategory[]
  products      Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

model SubCategory {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  categoryId String @db.ObjectId

  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  productCode String @unique
  productName String

  shopId        String @db.ObjectId
  categoryId    String @db.ObjectId
  subcategoryId String @db.ObjectId

  purchasePrice Float?
  price         Float
  stock         Int
  source        ProductSource? @default(REGULAR)

  imageUrl    String?
  mainImageUrl String?
  galleryImageUrls String[] @default([])
  description String?
  qrCode      String?
  barcode     String?

  shop        Shop        @relation(fields: [shopId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])
  subcategory SubCategory @relation(fields: [subcategoryId], references: [id])
  sales       Sale[]
  soldExchanges     Exchange[] @relation("SoldProduct")
  receivedExchanges Exchange[] @relation("ReceivedProduct")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exchange {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  employeeId        String @db.ObjectId
  shopId            String @db.ObjectId
  soldProductId     String @db.ObjectId
  receivedProductId String @db.ObjectId

  soldProductCode String
  soldProductName String
  soldProductPrice Float

  receivedProductCode String
  receivedProductName String
  receivedProductPrice Float
  exchangeValue       Float
  cashBalance         Float
  paymentMethod       PaymentMethod? @default(CASH)
  condition           String?
  notes               String?

  employee        User    @relation(fields: [employeeId], references: [id])
  shop            Shop    @relation(fields: [shopId], references: [id])
  soldProduct     Product @relation("SoldProduct", fields: [soldProductId], references: [id])
  receivedProduct Product @relation("ReceivedProduct", fields: [receivedProductId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([shopId])
  @@index([soldProductId])
  @@index([receivedProductId])
}

model Sale {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  employeeId String @db.ObjectId
  productId  String @db.ObjectId
  shopId     String @db.ObjectId

  productCode String
  productName String
  quantity    Int

  unitPrice     Float
  purchasePrice Float?
  discount      Float  @default(0)
  totalAmount   Float
  profit        Float
  proofType     String?
  proofFrontImageUrl  String?
  proofBackImageUrl   String?
  proofFrontPublicId  String?
  proofBackPublicId   String?

  employee User    @relation(fields: [employeeId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  shop     Shop    @relation(fields: [shopId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([productId])
  @@index([shopId])
}
